APP_NAME=LaraHostPanel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Port the panel's Nginx is exposed on (maps to container port 80)
APP_PORT=8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MySQL — matches the larahostpanel_mysql Docker container
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=larahostpanel
DB_USERNAME=larahostpanel
DB_PASSWORD=secret
DB_ROOT_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Redis — matches the larahostpanel_redis Docker container
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@larahostpanel.local"
MAIL_FROM_NAME="${APP_NAME}"

# Port phpMyAdmin is exposed on (optional, internal only)
PHPMYADMIN_PORT=8080
